# MZC Service
MZC_HOST=127.0.0.1
MZC_PORT=8765
MZC_LOG_LEVEL=INFO

# Paths (override per-machine; leave empty to use defaults relative to project)
# Example: MZC_CLAUDE_HOME=C:\Users\YourName
MZC_CLAUDE_HOME=
MZC_DB_PATH=
MZC_LOG_PATH=

# Claude Code CLI
MZC_CLAUDE_CLI=claude

# Feishu (fill in after creating self-built app)
MZC_FEISHU_APP_ID=
MZC_FEISHU_APP_SECRET=
MZC_FEISHU_WEBHOOK_VERIFY_TOKEN=
MZC_FEISHU_WEBHOOK_ENCRYPT_KEY=

# Cloudflare Access (filled in Phase 5)
MZC_CF_ACCESS_AUD=
MZC_CF_ACCESS_TEAM_DOMAIN=
