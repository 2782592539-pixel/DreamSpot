# MZC Service
MZC_HOST=127.0.0.1
MZC_PORT=8765
MZC_LOG_LEVEL=INFO

# Paths - uncomment to override the code defaults
# MZC_CLAUDE_HOME=C:\Users\YourName
# MZC_DB_PATH=C:\path\to\data\mzc.db
# MZC_LOG_PATH=C:\path\to\logs\mzc.log

# Claude Code CLI
MZC_CLAUDE_CLI=claude

# Feishu
# 1. Easiest: create a "Custom Bot" in a Feishu group, copy its webhook URL here.
#    Get the URL: 飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
#    Result URL looks like: https://open.feishu.cn/hook/<uuid>
MZC_FEISHU_WEBHOOK_URL=

# 2. Only needed if you also build a full Feishu app (for receiving callbacks):
MZC_FEISHU_APP_ID=
MZC_FEISHU_APP_SECRET=
MZC_FEISHU_WEBHOOK_VERIFY_TOKEN=
MZC_FEISHU_WEBHOOK_ENCRYPT_KEY=

# Cloudflare Access (filled in Phase 5)
MZC_CF_ACCESS_AUD=
MZC_CF_ACCESS_TEAM_DOMAIN=
